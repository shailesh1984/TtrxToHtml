{
    "Config": {
        "ProjectName": "trx-to-html-converter",
        "Author": "Shailesh M"
    },
    "Build": {
        "BuildConfiguration": "Release",
        "Runtime": "win-x64",
        "Version": "0.1.1",
        "SolutionFile": "./../src/TtrxToHtml.sln",
        "ArtifactDirectory": "./artifacts",
        "OutputDirectory": "/publish",
        "ZipFileName": "/TtrxToHtml.zip",
        "ExecutableName": "ttrx-to-html-{0}"
    },
    "Paths": {
        "ReleaseNotes": "./release-notes.md",
        "LogFile": "./logs/grm.log",
        "TargetDirectory": "./artifacts/repo",
        "InputTextFile": "./resources/release-notes-input.txt"
    },
    "Test": {
        "TrxFileName": "ttrx-to-html-test-result-{0}.trx",
        "ResultsDirectory": "./test-results"
    },
    "GitHub": {
        "Token": "",
        "RepoOwner": "shailesh1984",
        "RepoName": "trx-to-html-converter",
        "ReleaseTagName": "v{0}"
    }
}